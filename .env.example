APP_NAME=Agentic RAG Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

POSTGRES_DB=rag_agent
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_agent
SYNC_DATABASE_URL=postgresql+psycopg://rag_user:rag_password@localhost:5432/rag_agent

REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=rag-agent

MODEL_PROVIDER=openai_compatible
MODEL_BASE_URL=https://api.example.com/v1
MODEL_API_KEY=
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3
RERANK_MODEL=gte-rerank
OCR_PROVIDER=external_api
RERANK_API_BASE=
RERANK_API_KEY=
RERANK_ENABLED=false

RAG_TOP_K=8
RAG_SCORE_THRESHOLD=0
RERANK_TOP_K=6
KEYWORD_RECALL_ENABLED=true
KEYWORD_TOP_K=6
HYBRID_FUSION_METHOD=weighted
PROMPT_TEMPLATE_NAME=rag_default
PROMPT_TEMPLATE_VERSION=v1
RULE_MATCH_THRESHOLD=0.6

VITE_API_BASE_URL=http://127.0.0.1:8000
