APP_NAME=Agentic RAG Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

POSTGRES_DB=rag_agent
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_agent
SYNC_DATABASE_URL=postgresql+psycopg://rag_user:rag_password@localhost:5432/rag_agent

REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=rag-agent

MODEL_PROVIDER=openai_compatible
MODEL_BASE_URL=https://api.example.com/v1
MODEL_API_KEY=
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3
RERANK_MODEL=gte-rerank
OCR_PROVIDER=external_api

VITE_API_BASE_URL=http://127.0.0.1:8000
